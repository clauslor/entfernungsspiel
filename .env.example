# /etc/entfernungsspiel.env
# Copy this file to /etc/entfernungsspiel.env on the server and fill in the values.
# The file is read by the systemd unit via EnvironmentFile=.
# Keep this file readable only by root and the service user:
#   sudo chown root:www-data /etc/entfernungsspiel.env
#   sudo chmod 640 /etc/entfernungsspiel.env

# --- Required secrets ---
HCAPTCHA_SITE_KEY=259e5380-5d2e-4d64-8184-ad0896de011c
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
ADMIN_PASSWORD=your_secure_admin_password

# --- Server ---
HOST=0.0.0.0
PORT=9000
DEBUG=false

# --- Database ---
DATABASE_URL=sqlite:////opt/entfernungsspiel/highscores.db

# --- CORS: comma-separated list of allowed origins ---
ALLOWED_ORIGINS=https://entfernungsspiel.tianalorenz.de

# --- Logging ---
LOG_LEVEL=INFO
# Leave empty to log to stdout/stderr (captured by systemd journald)
LOG_FILE=

# --- Game defaults ---
DEFAULT_MAX_ROUNDS=1
DEFAULT_COUNTDOWN=3
DEFAULT_ANSWER_TIME=15
DEFAULT_PAUSE_BETWEEN_ROUNDS=3
DEFAULT_ENABLE_ROAD_QUESTIONS=true
DEFAULT_ROAD_QUESTION_RATIO_PERCENT=50

# --- Routing (optional, for road-distance questions) ---
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org
# GRAPHHOPPER_API_KEY=
# GRAPHHOPPER_PROFILE=car
